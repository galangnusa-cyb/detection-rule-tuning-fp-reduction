index=* source=*eve.json event_type=flow

/* OPTIONAL allowlist: replace placeholders or remove this line */
| search NOT src_ip IN ("<IP_INTERNAL_SCANNER>", "<IP_MONITORING>")

| bin _time span=2m
| stats dc(dest_port) as unique_ports values(dest_port) as ports count as flows by _time, src_ip, dest_ip
| where unique_ports>=30
| eval severity=case(unique_ports>=100,"high", unique_ports>=50,"medium", true(),"low")
| where severity!="low"
| sort -unique_ports
