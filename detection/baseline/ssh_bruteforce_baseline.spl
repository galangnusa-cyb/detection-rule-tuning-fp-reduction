index=* (source="/var/log/auth.log" OR sourcetype=linux_secure OR sourcetype=auth*)
("Failed password" OR "authentication failure")
| rex "from (?<src_ip>\d{1,3}(?:\.\d{1,3}){3})"
| bin _time span=5m
| stats count as fails dc(user) as distinct_users values(user) as users by _time, src_ip, host
| where fails>=5
| sort -fails
